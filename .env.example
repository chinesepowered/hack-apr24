# ----- LLM (OpenAI-compatible; GLM 5.1 target) -----
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_API_KEY=
OPENAI_MODEL=glm-5.1

# ----- GitHub App -----
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_INSTALLATION_ID=
GITHUB_DEMO_REPO=owner/repo

# ----- Guild.ai -----
# When set to 1, the orchestrator skips spawning the Guild planner subprocess
# (services/agents/planner) and falls back to in-process LLM / mock plans.
GUILD_PLANNER_DISABLED=0
GUILD_API_KEY=
GUILD_WORKSPACE_ID=

# ----- Ghost -----
GHOST_API_KEY=
GHOST_BASE_DATABASE=branch-prod
# Optional: pin the Ghost space id. If unset, the adapter uses the only space
# the API key is scoped to.
GHOST_SPACE_ID=

# ----- Wundergraph Cosmo -----
COSMO_API_KEY=
COSMO_ROUTER_URL=http://localhost:3002/graphql
COSMO_CDN_URL=
# When set, the orchestrator's verify phase hits the real router instead of
# returning canned data. Point at the local router for the live stack demo.
ROUTER_URL=

# ----- Postgres (live stack demo) -----
DATABASE_URL=postgres://branch:branch@localhost:5432/branch_prod

# ----- InsForge (self-hosted default) -----
# Bootstrap the schema once with packages/adapters/insforge/sql/bootstrap.sql.
INSFORGE_URL=http://localhost:7130
INSFORGE_API_KEY=
INSFORGE_BUCKET=branch-artifacts
INSFORGE_EMBED_MODEL=openai/text-embedding-3-small

# ----- Slack -----
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ----- Chainguard -----
CHAINGUARD_PULL_TOKEN_USERNAME=
CHAINGUARD_PULL_TOKEN_PASSWORD=
# Optional: path mounted into the apko sidecar. Defaults to the process cwd
# (repo root when launched via pnpm demo:live).
BRANCH_WORKSPACE_ROOT=

# ----- Tunneling (demo) -----
NGROK_AUTHTOKEN=

# ----- Mock toggles (1 = force mock adapter) -----
USE_MOCK_GHOST=0
USE_MOCK_INSFORGE=0
USE_MOCK_WUNDERGRAPH=0
USE_MOCK_GITHUB=0
USE_MOCK_CHAINGUARD=0
USE_MOCK_SLACK=0
